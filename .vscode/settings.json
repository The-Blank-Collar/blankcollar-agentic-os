{
  "files.eol": "\n",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.renderWhitespace": "boundary",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "[python]": { "editor.tabSize": 4 },
  "[shellscript]": { "editor.tabSize": 4 },
  "files.exclude": {
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true
  }
}
