# =============================================================================
# Blank Collar — Agentic OS · .env.example
# -----------------------------------------------------------------------------
# Copy to `.env` and edit as needed:
#
#     cp .env.example .env
#
# For Phase 0 (Groundwork) you do NOT need any external API keys — the data
# layer runs locally with the defaults below. Future phases will require the
# placeholder keys at the bottom of this file.
#
# RULE: never commit `.env`. Only `.env.example` is tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Project metadata
# -----------------------------------------------------------------------------
PROJECT_NAME=blankcollar
ENV=local
LOG_LEVEL=info
PUBLIC_DOMAIN=www.blankcollar.ai
AGENT_EMAIL=agent@blankcollar.ai

# Public domains used by Caddy in production (docker-compose.prod.yml).
# Point an A record for each at the VPS IP, then Caddy auto-issues TLS.
NANGO_PUBLIC_DOMAIN=nango.blankcollar.ai
NANGO_UI_DOMAIN=nango-ui.blankcollar.ai
ACME_EMAIL=agent@blankcollar.ai

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blankcollar
POSTGRES_PORT=5432
# Convenience: full URL form for apps that prefer it
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/blankcollar

# -----------------------------------------------------------------------------
# Neo4j (graph backend for Graphiti)
# -----------------------------------------------------------------------------
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URI=bolt://neo4j:7687
# Memory tuning. Bump if you have RAM to spare; lower for a tight laptop.
NEO4J_HEAP_INIT=512m
NEO4J_HEAP_MAX=1g
NEO4J_PAGECACHE=512m

# -----------------------------------------------------------------------------
# Graphiti (temporal knowledge graph wrapper)
# -----------------------------------------------------------------------------
GRAPHITI_PORT=8004
# In-cluster URL gbrain uses to reach graphiti (best-effort bridge).
GRAPHITI_URL=http://graphiti:80
# graphiti-core uses an LLM to extract entities + relationships per episode.
# Without an API key, /add returns {skipped: true, reason: "no_llm_configured"}.
GRAPHITI_LLM_MODEL=gpt-4o-mini
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Qdrant (vector store)
# -----------------------------------------------------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# Leave empty for local-only. Set to a strong key when exposing Qdrant.
QDRANT_API_KEY=
QDRANT_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# Paperclip (orchestrator + dashboard)
# -----------------------------------------------------------------------------
PAPERCLIP_PORT=3000
# In-cluster URL other services use to reach Paperclip.
PAPERCLIP_URL=http://paperclip:80
# Real Paperclip (upstream paperclipai) — primary command centre UI.
PAPERCLIP_REAL_PORT=3100
# Used by the future API to sign session/JWT cookies. Generate with:
#   openssl rand -hex 32
PAPERCLIP_AUTH_SECRET=replace-me-with-a-32-byte-hex-string
# Until real auth ships (Phase 6), every request resolves to the demo org's owner.
PAPERCLIP_DEFAULT_ORG_SLUG=blankcollar-demo
# In-process queue worker tuning. Disable with PAPERCLIP_WORKER_ENABLED=false.
PAPERCLIP_WORKER_POLL_MS=1500
PAPERCLIP_WORKER_ENABLED=true
# In-cluster URL Paperclip uses to reach gbrain.
GBRAIN_URL=http://gbrain:80

# -----------------------------------------------------------------------------
# Hermes Agent (general-purpose reasoning)
# -----------------------------------------------------------------------------
HERMES_PORT=8001
HERMES_API_KEY=
# In-cluster URL Paperclip uses to dispatch runs to Hermes.
HERMES_URL=http://hermes:80
# LLM model + budget. Without ANTHROPIC_API_KEY, Hermes falls back to FakeLLM.
HERMES_MODEL=claude-sonnet-4-6
HERMES_MAX_TOKENS=1024
HERMES_MAX_RECALL=8

# -----------------------------------------------------------------------------
# LangGraph Dispatcher (multi-agent orchestrator on top of Hermes + OpenClaw)
# -----------------------------------------------------------------------------
LANGGRAPH_PORT=8005
LANGGRAPH_URL=http://langgraph:80
# Classifier picks the model from the same LLM precedence Hermes uses
# (NEXOS > ANTHROPIC > OPENAI > keyword fallback).
LANGGRAPH_CLASSIFIER_MODEL=claude-sonnet-4-6
LANGGRAPH_CLASSIFIER_MAX_TOKENS=200
# Hard cap on graph cycles per run, to prevent infinite loops.
LANGGRAPH_MAX_CYCLES=4
LANGGRAPH_POLL_INTERVAL_S=0.5
LANGGRAPH_POLL_TIMEOUT_S=180

# -----------------------------------------------------------------------------
# OpenClaw Agent (tool / web actions)
# -----------------------------------------------------------------------------
OPENCLAW_PORT=8002
OPENCLAW_API_KEY=
OPENCLAW_URL=http://openclaw:80
# Politeness controls for web.fetch
OPENCLAW_FETCH_TIMEOUT_S=10
OPENCLAW_FETCH_MAX_BYTES=1500000
OPENCLAW_USER_AGENT="BlankCollar-OpenClaw/0.1 (+https://www.blankcollar.ai)"
OPENCLAW_TEXT_EXCERPT_CHARS=8000

# web.browse (Playwright + headless Chromium)
OPENCLAW_BROWSER_TIMEOUT_S=30
OPENCLAW_BROWSER_VIEWPORT_W=1280
OPENCLAW_BROWSER_VIEWPORT_H=800
OPENCLAW_BROWSER_MAX_SCREENSHOT_BYTES=2000000

# Oxylabs AI Studio (web.search skill). When OXYLABS_API_KEY is empty,
# OpenClaw falls back to DuckDuckGo Instant Answers so the demo runs.
OXYLABS_API_KEY=
OXYLABS_BASE_URL=https://api.aistudio.oxylabs.io
OXYLABS_SEARCH_PATH=/v1/search
OXYLABS_DEFAULT_RESULTS=10
OXYLABS_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# Brand Foundation (design.md). The runtime layer Hermes and OpenClaw use to
# pull voice/banned-words/positioning into every response. Default file:
# brand/blankcollar.md (mounted read-only at /app/brand inside containers).
# Swap by adding brand/<your-org>.md and setting BRAND_NAME=<your-org>.
# -----------------------------------------------------------------------------
BRAND_DIR=/app/brand
BRAND_NAME=blankcollar

# -----------------------------------------------------------------------------
# gbrain (memory layer)
# -----------------------------------------------------------------------------
GBRAIN_PORT=8003
# Default embedding model used to populate the Company Brain.
GBRAIN_EMBED_MODEL=text-embedding-3-small
GBRAIN_EMBED_DIM=1536

# -----------------------------------------------------------------------------
# LLM providers — Hermes prefers Nexos > Anthropic > FakeLLM (no key)
# -----------------------------------------------------------------------------
# Nexos.ai (Hostinger AI gateway, OpenAI-compatible Chat Completions)
NEXOS_API_KEY=
NEXOS_BASE_URL=https://api.nexos.ai/v1
# Available models per Hostinger's nexos.ai guide:
#   claude-sonnet · claude-opus · gpt-4.1 · gemini-3-flash · grok-4
NEXOS_MODEL=claude-sonnet

# Direct providers (handy for local dev / fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# pgAdmin (only used when you run with `--profile tools`)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@blankcollar.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# =============================================================================
# FUTURE PHASES — placeholders only, no value required today
# =============================================================================

# --- Supabase (auth + roles) -------------------------------------------------
# When SUPABASE_JWT_SECRET is set, Paperclip's API routes verify incoming
# `Authorization: Bearer <jwt>` tokens. When unset, every caller resolves to
# the demo org's owner (today's behaviour). Get the JWT secret from your
# Supabase project: Settings → API → JWT Secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Set to `true` to require a valid JWT on every API call. Default: false
# (verify when present, fall back to stub when absent).
PAPERCLIP_AUTH_ENFORCE=false

# --- Nango (OAuth + tool integrations gateway) ------------------------------
# Self-hosted Nango server lets agents call 400+ external APIs (Slack, Notion,
# GitHub, etc.) through a single proxy. After bring-up, open the Connect UI at
# http://localhost:3009 to register your first integration. See docs/NANGO.md.
NANGO_SERVER_PORT=3003
NANGO_CONNECT_UI_PORT=3009
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=nango
NANGO_DB_NAME=nango
NANGO_DB_HOST=nango-db
NANGO_DB_INTERNAL_PORT=5432
# 32-byte base64. CHANGE THIS in production. Generate with:
#   openssl rand -base64 32
NANGO_ENCRYPTION_KEY=RZwOryJRG/8AvoR6yeqrh4QkgZUQOK+2
# URLs Nango uses to reference itself in OAuth callbacks etc.
NANGO_SERVER_URL=http://localhost:3003
NANGO_PUBLIC_SERVER_URL=http://localhost:3003
# Flip to "true" + set the dashboard credentials below before you expose Nango
# to anything beyond localhost.
NANGO_FLAG_AUTH_ENABLED=false
NANGO_DASHBOARD_USERNAME=admin
NANGO_DASHBOARD_PASSWORD=admin
NANGO_LOG_LEVEL=info
# In-cluster URL OpenClaw uses to reach Nango.
NANGO_URL=http://nango:3003
# Nango server-side secret key for the OpenClaw → Nango proxy calls. Find this
# in the Nango dashboard after first-run (Environment Settings → Secret Key).
# Empty value disables the nango.invoke skill at runtime (returns a clear
# error message instead of crashing).
NANGO_SECRET_KEY=

# --- Stripe (billing) --------------------------------------------------------
# Paperclip exposes POST /api/webhooks/stripe — verifies the Stripe-Signature
# header against STRIPE_WEBHOOK_SECRET and records events idempotently in
# billing.stripe_event. The endpoint returns 503 if STRIPE_WEBHOOK_SECRET is
# unset, so the rest of the stack stays healthy without billing configured.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email pipeline (agent@blankcollar.ai) -----------------------------------
# Outbound (used by OpenClaw's email.send skill). Empty values = "drafted" mode
# (email NOT sent; the message is still recorded as a memory).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@blankcollar.ai
SMTP_USE_TLS=false
SMTP_TIMEOUT_S=20

# Inbound (used by the email-ingest service). When IMAP_HOST/IMAP_USER are
# empty, email-ingest runs in idle/heartbeat mode (no polling).
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
EMAIL_POLL_INTERVAL_S=60
INBOUND_EMAIL_WEBHOOK_SECRET=
