# =============================================================================
# Blank Collar — Agentic OS · .env.example
# -----------------------------------------------------------------------------
# Copy to `.env` and edit as needed:
#
#     cp .env.example .env
#
# For Phase 0 (Groundwork) you do NOT need any external API keys — the data
# layer runs locally with the defaults below. Future phases will require the
# placeholder keys at the bottom of this file.
#
# RULE: never commit `.env`. Only `.env.example` is tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Project metadata
# -----------------------------------------------------------------------------
PROJECT_NAME=blankcollar
ENV=local
LOG_LEVEL=info
PUBLIC_DOMAIN=www.blankcollar.ai
AGENT_EMAIL=agent@blankcollar.ai

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blankcollar
POSTGRES_PORT=5432
# Convenience: full URL form for apps that prefer it
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/blankcollar

# -----------------------------------------------------------------------------
# Qdrant (vector store)
# -----------------------------------------------------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# Leave empty for local-only. Set to a strong key when exposing Qdrant.
QDRANT_API_KEY=
QDRANT_URL=http://qdrant:6333

# -----------------------------------------------------------------------------
# Paperclip (orchestrator + dashboard)
# -----------------------------------------------------------------------------
PAPERCLIP_PORT=3000
# In-cluster URL other services use to reach Paperclip.
PAPERCLIP_URL=http://paperclip:80
# Real Paperclip (upstream paperclipai) — primary command centre UI.
PAPERCLIP_REAL_PORT=3100
# Used by the future API to sign session/JWT cookies. Generate with:
#   openssl rand -hex 32
PAPERCLIP_AUTH_SECRET=replace-me-with-a-32-byte-hex-string
# Until real auth ships (Phase 6), every request resolves to the demo org's owner.
PAPERCLIP_DEFAULT_ORG_SLUG=blankcollar-demo
# In-process queue worker tuning. Disable with PAPERCLIP_WORKER_ENABLED=false.
PAPERCLIP_WORKER_POLL_MS=1500
PAPERCLIP_WORKER_ENABLED=true
# In-cluster URL Paperclip uses to reach gbrain.
GBRAIN_URL=http://gbrain:80

# -----------------------------------------------------------------------------
# Hermes Agent (general-purpose reasoning)
# -----------------------------------------------------------------------------
HERMES_PORT=8001
HERMES_API_KEY=
# In-cluster URL Paperclip uses to dispatch runs to Hermes.
HERMES_URL=http://hermes:80
# LLM model + budget. Without ANTHROPIC_API_KEY, Hermes falls back to FakeLLM.
HERMES_MODEL=claude-sonnet-4-6
HERMES_MAX_TOKENS=1024
HERMES_MAX_RECALL=8

# -----------------------------------------------------------------------------
# OpenClaw Agent (tool / web actions)
# -----------------------------------------------------------------------------
OPENCLAW_PORT=8002
OPENCLAW_API_KEY=
OPENCLAW_URL=http://openclaw:80
# Politeness controls for web.fetch
OPENCLAW_FETCH_TIMEOUT_S=10
OPENCLAW_FETCH_MAX_BYTES=1500000
OPENCLAW_USER_AGENT="BlankCollar-OpenClaw/0.1 (+https://www.blankcollar.ai)"
OPENCLAW_TEXT_EXCERPT_CHARS=8000

# Oxylabs AI Studio (web.search skill). When OXYLABS_API_KEY is empty,
# OpenClaw falls back to DuckDuckGo Instant Answers so the demo runs.
OXYLABS_API_KEY=
OXYLABS_BASE_URL=https://api.aistudio.oxylabs.io
OXYLABS_SEARCH_PATH=/v1/search
OXYLABS_DEFAULT_RESULTS=10
OXYLABS_TIMEOUT_S=30

# -----------------------------------------------------------------------------
# gbrain (memory layer)
# -----------------------------------------------------------------------------
GBRAIN_PORT=8003
# Default embedding model used to populate the Company Brain.
GBRAIN_EMBED_MODEL=text-embedding-3-small
GBRAIN_EMBED_DIM=1536

# -----------------------------------------------------------------------------
# LLM providers — Hermes prefers Nexos > Anthropic > FakeLLM (no key)
# -----------------------------------------------------------------------------
# Nexos.ai (Hostinger AI gateway, OpenAI-compatible Chat Completions)
NEXOS_API_KEY=
NEXOS_BASE_URL=https://api.nexos.ai/v1
# Available models per Hostinger's nexos.ai guide:
#   claude-sonnet · claude-opus · gpt-4.1 · gemini-3-flash · grok-4
NEXOS_MODEL=claude-sonnet

# Direct providers (handy for local dev / fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# pgAdmin (only used when you run with `--profile tools`)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@blankcollar.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# =============================================================================
# FUTURE PHASES — placeholders only, no value required today
# =============================================================================

# --- Supabase (auth + roles) -------------------------------------------------
# When SUPABASE_JWT_SECRET is set, Paperclip's API routes verify incoming
# `Authorization: Bearer <jwt>` tokens. When unset, every caller resolves to
# the demo org's owner (today's behaviour). Get the JWT secret from your
# Supabase project: Settings → API → JWT Secret.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Set to `true` to require a valid JWT on every API call. Default: false
# (verify when present, fall back to stub when absent).
PAPERCLIP_AUTH_ENFORCE=false

# --- Stripe (billing) --------------------------------------------------------
# Paperclip exposes POST /api/webhooks/stripe — verifies the Stripe-Signature
# header against STRIPE_WEBHOOK_SECRET and records events idempotently in
# billing.stripe_event. The endpoint returns 503 if STRIPE_WEBHOOK_SECRET is
# unset, so the rest of the stack stays healthy without billing configured.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email pipeline (agent@blankcollar.ai) -----------------------------------
# Outbound (used by OpenClaw's email.send skill). Empty values = "drafted" mode
# (email NOT sent; the message is still recorded as a memory).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agent@blankcollar.ai
SMTP_USE_TLS=false
SMTP_TIMEOUT_S=20

# Inbound (used by the email-ingest service). When IMAP_HOST/IMAP_USER are
# empty, email-ingest runs in idle/heartbeat mode (no polling).
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true
EMAIL_POLL_INTERVAL_S=60
INBOUND_EMAIL_WEBHOOK_SECRET=
