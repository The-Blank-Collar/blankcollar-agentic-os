# =============================================================================
# Blank Collar Agentic OS — Caddy v2 reverse proxy
#
# Three public TLS endpoints, all auto-issued + renewed via Let's Encrypt.
# Caddy is the only public-facing process; everything else is internal on
# bc_net.
#
#   {$PUBLIC_DOMAIN}        → paperclip:80   (dashboard + API + webhooks)
#   {$NANGO_PUBLIC_DOMAIN}  → nango:3003     (Nango API; OAuth callbacks land here)
#   {$NANGO_UI_DOMAIN}      → nango:3009     (Nango Connect UI; admin only)
#
# DNS: point all three names at the VPS IP. Caddy does the TLS dance on
# first request, then renews on a 60-day cycle.
#
# To debug TLS or routing, uncomment `debug` in the global block and
# `docker compose logs -f caddy`.
# =============================================================================

{
	email {$ACME_EMAIL}
	# debug
}

# -----------------------------------------------------------------------------
# Main app domain — the dashboard, the agent API, and Stripe webhooks.
# -----------------------------------------------------------------------------
{$PUBLIC_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		# Frame-busting for the dashboard. Loosen if you embed elsewhere.
		X-Frame-Options           "DENY"
	}

	# Stripe + future webhooks: forward as-is (raw body required for HMAC).
	@webhooks path /api/webhooks/*
	handle @webhooks {
		reverse_proxy paperclip:80
	}

	# Everything else (UI + API + healthz)
	handle {
		reverse_proxy paperclip:80
	}

	log {
		output stdout
		format json
		level INFO
	}
}

# -----------------------------------------------------------------------------
# Nango API — OAuth callbacks from Slack, Notion, GitHub etc. land here.
# Must be public TLS. Nango itself enforces its own auth on the dashboard
# routes; the /proxy and /oauth routes are intentionally callable.
# -----------------------------------------------------------------------------
{$NANGO_PUBLIC_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
	}

	reverse_proxy nango:3003

	log {
		output stdout
		format json
		level INFO
	}
}

# -----------------------------------------------------------------------------
# Nango Connect UI — wires up integrations interactively. Admin only.
# Set NANGO_FLAG_AUTH_ENABLED=true and a strong dashboard password before
# pointing real DNS here (the prod compose overlay defaults to true).
# -----------------------------------------------------------------------------
{$NANGO_UI_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
	}

	reverse_proxy nango:3009

	log {
		output stdout
		format json
		level INFO
	}
}

# -----------------------------------------------------------------------------
# Optional: redirect apex → www. Uncomment + edit when you bind both.
# -----------------------------------------------------------------------------
# blankcollar.ai {
# 	redir https://www.blankcollar.ai{uri}
# }
